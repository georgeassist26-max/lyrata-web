---
// FaqSection.astro
// Static Ocean — Sección de Preguntas Frecuentes (AEO)
// Contenido visible que respalda el FAQPage JSON-LD del BaseLayout.
// 100% HTML server-rendered. Acordeón nativo <details>/<summary> = cero JS.
import propertyData from '../../content/propertyData.json';

const model = propertyData.models.find((m) => m.id === 'livet-v2')!;

const faqs = [
  {
    q: `¿Cuánto cuesta la casa modelo LIVET V.2 en Lyrata Edén Urbano?`,
    a: `El modelo LIVET V.2 tiene un precio de ${model.price}. Incluye ${model.rooms.bedrooms} recámaras, ${model.rooms.bathrooms} baños y ${model.dimensions.constructionArea} de construcción en León, Guanajuato.`,
  },
  {
    q: `¿Dónde se ubica el desarrollo Lyrata Edén Urbano?`,
    a: `Lyrata Edén Urbano es un desarrollo residencial de casas nuevas en León, Guanajuato, con acceso controlado, circuito cerrado de cámaras y malla electrificada perimetral en toda la privada.`,
  },
  {
    q: `¿Cuántas recámaras y baños tiene el modelo LIVET V.2?`,
    a: `El modelo LIVET V.2 cuenta con ${model.rooms.bedrooms} recámaras (incluida una recámara principal con vestidor y baño completo independiente), ${model.rooms.bathrooms} baños y cochera para ${model.rooms.parkingSpaces} autos.`,
  },
  {
    q: `¿Qué tecnología y equipamiento incluye la casa?`,
    a: `Incluye cerradura inteligente en puerta principal, calentador solar de 150 L, cisterna de 3,000 L con bomba, y preparación para minisplits, gas natural, internet y cargador de auto eléctrico.`,
  },
];
---

<section class="bg-zinc-950 py-24" aria-labelledby="faq-heading">
  <div class="max-w-3xl mx-auto px-4">
    <!-- Header -->
    <p class="text-xs uppercase tracking-widest text-slate-500 mb-4 text-center">Preguntas Frecuentes</p>
    <h2 id="faq-heading" class="text-4xl md:text-5xl font-light text-white mb-12 text-center">
      Todo lo que necesitas saber.
    </h2>

    <!-- Accordion -->
    <div class="space-y-4">
      {
        faqs.map((item) => (
          <details class="group bg-zinc-900 border border-white/5 rounded-2xl overflow-hidden transition-colors duration-300 hover:border-white/15">
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none p-6 text-white font-medium select-none">
              <span>{item.q}</span>
              <svg
                class="w-5 h-5 shrink-0 text-emerald-400 transition-transform duration-300 group-open:rotate-45"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </summary>
            <div class="px-6 pb-6 -mt-1 text-slate-400 leading-relaxed">
              {item.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Hide default disclosure marker across browsers */
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
