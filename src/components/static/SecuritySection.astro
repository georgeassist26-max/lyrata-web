---
// SecuritySection.astro
// Static Ocean — Dark tech-focused security section
// 100% server-rendered HTML, zero client JS
---

<div class="bg-zinc-950 py-24">
  <div class="max-w-7xl mx-auto px-4 text-center">

    <!-- Header -->
    <p class="text-xs uppercase tracking-widest text-slate-500 mb-4">Seguridad</p>
    <h2 class="text-4xl md:text-5xl font-light text-white mb-6">Paz Mental Absoluta.</h2>
    <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-16">Tu familia, blindada por tecnología.</p>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Card 1 -->
      <div class="bg-zinc-900 p-8 rounded-3xl border border-white/5 flex flex-col items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-emerald-400/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
        </div>
        <p class="text-white font-medium text-center">Acceso biométrico con reconocimiento facial</p>
      </div>

      <!-- Card 2 -->
      <div class="bg-zinc-900 p-8 rounded-3xl border border-white/5 flex flex-col items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-emerald-400/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
        </div>
        <p class="text-white font-medium text-center">Bardas perimetrales de 4.60m con cerco electrificado (1,400V)</p>
      </div>

      <!-- Card 3 -->
      <div class="bg-zinc-900 p-8 rounded-3xl border border-white/5 flex flex-col items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-emerald-400/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
          </svg>
        </div>
        <p class="text-white font-medium text-center">Red de 34 cámaras de circuito cerrado monitoreando cada ángulo</p>
      </div>

    </div>
  </div>
</div>
