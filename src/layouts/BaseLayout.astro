---
import propertyData from '../content/propertyData.json';
import siteConfig from '../config/site.config.json';
import { hasWhatsApp } from '../lib/leads';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Lyrata Edén Urbano — Casas nuevas residenciales en León, Guanajuato. Modelo LIVET V.2: 3 recámaras, 187.65 m² de construcción, acabados premium y tecnología inteligente.',
  ogImage = '/og-livet-v2.jpg',
} = Astro.props;

// Canonical site origin. Override via PUBLIC_SITE_URL env at build time when domain is final.
const SITE_URL = (import.meta.env.PUBLIC_SITE_URL ?? siteConfig.siteUrl).replace(/\/$/, '');
const canonical = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = new URL(ogImage, SITE_URL).href;

// Extract development and model data
const development = propertyData.development;
const model = propertyData.models.find((m) => m.id === siteConfig.activeModelId)!;

// CRITICAL: Strip "$", ",", and " MXN" → raw integer (e.g. "$3,370,000 MXN" → 3370000)
const rawPrice = parseInt(model.price.replace(/[$,]/g, '').replace(' MXN', '').trim(), 10);

// Analytics: cada vendor se inyecta SOLO si su ID está configurado en site.config.json
const A = siteConfig.analytics;

// Build schema.org SingleFamilyResidence
// Nota: sin aggregateRating/review — solo datos verificables (los reviews fabricados
// violan las políticas de datos estructurados de Google y arriesgan penalización).
const schema = {
  '@context': 'https://schema.org',
  '@type': 'SingleFamilyResidence',
  name: `${development.name} — ${model.name}`,
  description: description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'León',
    addressRegion: 'Guanajuato',
    addressCountry: 'MX',
  },
  floorSize: {
    '@type': 'QuantitativeValue',
    value: 187.65,
    unitCode: 'MTK',
  },
  url: canonical,
  image: [
    ogImageUrl,
    `${SITE_URL}/images/entorno-natural.webp`,
    `${SITE_URL}/images/alberca.webp`,
    `${SITE_URL}/images/gym.webp`,
    `${SITE_URL}/images/sustentabilidad.webp`,
    `${SITE_URL}/images/sala-flex.webp`,
    `${SITE_URL}/images/big-bathroom.webp`
  ],
  numberOfRooms: model.rooms.bedrooms,
  numberOfBedrooms: model.rooms.bedrooms,
  numberOfBathroomsTotal: model.rooms.bathrooms,
  numberOfParkingSpaces: model.rooms.parkingSpaces,
  lotSize: {
    '@type': 'QuantitativeValue',
    value: 120.60,
    unitCode: 'MTK',
  },
  offers: {
    '@type': 'Offer',
    price: rawPrice,
    priceCurrency: 'MXN',
    priceValidUntil: '2026-12-31',
    availability: 'https://schema.org/InStock',
    url: canonical,
    seller: {
      '@type': 'RealEstateAgent',
      name: siteConfig.brandName,
      image: `${SITE_URL}/synexia-logo-transparent.png`,
      priceRange: '$$$',
      ...(hasWhatsApp ? { telephone: `+${siteConfig.whatsapp.number}` } : {}),
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'León',
        addressRegion: 'Guanajuato',
        addressCountry: 'MX',
      }
    },
  },
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Alberca Climatizada', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Gimnasio Equipado', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Espacio de Co-working', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Parque para Mascotas (Pet Park)', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Cancha Deportiva de Básquetbol', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Acceso Controlado Facial', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Circuito Cerrado de Cámaras (CCTV)', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Cerco Electrificado perimetral', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Área Doggy debajo de escaleras', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Preparación para auto eléctrico', value: true }
  ],
};

// AEO: FAQPage schema — what answer engines (ChatGPT, Perplexity, Google AI) quote directly.
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es Lyrata Edén Urbano y dónde está exactamente ubicado?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Lyrata Edén Urbano es un desarrollo residencial premium ideal para familias que buscan exclusividad y contacto con la naturaleza, ubicado exactamente en la zona norte de León, Guanajuato, con un acceso rápido por Boulevard Hidalgo y Boulevard José María Morelos.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Cuáles son las dimensiones y características exactas del Modelo Livet V.2?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `El Modelo Livet V.2 cuenta con un lote de 6.70 x 18.00 metros (${model.dimensions.landArea} de terreno), ${model.dimensions.constructionArea} de construcción distribuidos eficientemente, ${model.rooms.bedrooms} recámaras bien iluminadas y ${model.rooms.bathrooms} baños equipados con acabados de la más alta calidad.`
      }
    },
    {
      '@type': 'Question',
      name: '¿Cuál es el precio o esquema de inversión para adquirir una casa en Lyrata?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `El modelo LIVET V.2 tiene un precio de ${model.price}. Ofrecemos una amplia gama de opciones de financiamiento atractivas, esquemas personalizados de enganche diferido y soporte total para créditos hipotecarios bancarios.`
      }
    },
    {
      '@type': 'Question',
      name: '¿Qué amenidades exclusivas tiene la privada Lyrata?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La privada cuenta con una Casa Club premium que incluye alberca climatizada de diseño exclusivo (oculta a la vista de la calle para tu privacidad), gimnasio equipado, espacio de co-working para trabajo remoto, parque para mascotas (pet-park) y cancha deportiva de básquetbol rodeada de áreas verdes.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Es un desarrollo seguro para mi familia?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí, Lyrata Edén Urbano cuenta con el más alto nivel de seguridad del mercado: accesos inteligentes controlados mediante tecnología de reconocimiento facial, una red integrada de 23 cámaras de circuito cerrado (CCTV), barda perimetral reforzada de hasta 4.60 metros de altura y cerco electrificado de alta potencia de 1,400 voltios.'
      }
    },
    {
      '@type': 'Question',
      name: '¿El Modelo Livet V.2 está adaptado para mascotas y trabajo remoto?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Totalmente. El diseño inteligente incluye un área "Doggy" exclusiva debajo de las escaleras especialmente diseñada para mascotas, y una Zona Flex sumamente amplia en la planta alta, perfecta para home office o home school.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Por qué el entorno urbano de Lyrata ofrece una mejor calidad de vida frente a otros desarrollos?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'El entorno de Lyrata destaca por su diseño orgánico y sustentable que respeta e integra árboles maduros de gran formato (tales como flama china y trueno) para dar sombra inmediata. Además, sus fachadas están vestidas con materiales de bajo mantenimiento como cantera natural, que envejecen de manera hermosa con el tiempo.'
      }
    },
    {
      '@type': 'Question',
      name: '¿Cómo está diseñado el Modelo Livet V.2 para la vida moderna y la eficiencia?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Está diseñado con una separación inteligente entre las áreas sociales y el área de servicios, un cuarto de servicio techado e independiente, calentador solar integrado de alta capacidad (150 L) y con la preparación para conectar cargadores de autos eléctricos (EV Ready).'
      }
    },
    {
      '@type': 'Question',
      name: '¿Cómo facilita Synexia la conexión con este desarrollo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'En Synexia no somos simples intermediarios transaccionales; brindamos un apoyo absoluto a lo largo de todo tu proceso de compra. Facilitamos una conexión transparente, directa y confiable con las opciones de inversión de mayor plusvalía, garantizando la máxima claridad y decisiones financieras inteligentes para tu patrimonio.'
      }
    }
  ]
};

// Valores que consumen los scripts inline de tracking
const trackingVars = {
  SITE_ID: siteConfig.siteId,
  SITE_NAME: siteConfig.siteName,
  MODEL_ID: model.id,
  MODEL_NAME: model.name,
  LEAD_VALUE: siteConfig.leadValue,
  CURRENCY: siteConfig.currency,
  ADS_SEND_TO: A.googleAdsSendTo,
  LI_CONVERSION_ID: A.linkedinConversionId,
  LEAD_WEBHOOK: siteConfig.leadWebhook,
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#000000" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- LCP preload: hero AVIF (smallest), fetched at highest priority -->
    <link rel="preload" as="image" href="/3-houses-front.avif" type="image/avif" fetchpriority="high" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:site_name" content={siteConfig.brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />

    <!-- ══════════ ATRIBUCIÓN: captura UTM/gclid/fbclid (first-touch en localStorage) ══════════ -->
    <script is:inline>
      (function () {
        var EMPTY = {};
        try {
          var KEY = 'lead_attr';
          var params = new URLSearchParams(location.search);
          var KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'gclid', 'fbclid'];
          var found = {}, has = false;
          KEYS.forEach(function (k) { var v = params.get(k); if (v) { found[k] = v.slice(0, 120); has = true; } });
          var stored = null;
          try { stored = JSON.parse(localStorage.getItem(KEY) || 'null'); } catch (e) {}
          if (!stored) {
            stored = { ts: new Date().toISOString(), landing: location.pathname, referrer: document.referrer.slice(0, 200) };
            KEYS.forEach(function (k) { if (found[k]) stored[k] = found[k]; });
            try { localStorage.setItem(KEY, JSON.stringify(stored)); } catch (e) {}
          } else if (has) {
            // Conserva first-touch; registra el último touch de campaña aparte
            stored.last = { ts: new Date().toISOString() };
            KEYS.forEach(function (k) { if (found[k]) stored.last[k] = found[k]; });
            try { localStorage.setItem(KEY, JSON.stringify(stored)); } catch (e) {}
          }
          window.getLeadAttribution = function () { return stored || EMPTY; };
        } catch (e) {
          window.getLeadAttribution = function () { return EMPTY; };
        }
      })();
    </script>

    {A.ga4 && (
      <>
        <!-- Google Analytics 4 -->
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${A.ga4}`} is:inline></script>
        <script is:inline define:vars={{ GA4_ID: A.ga4 }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </>
    )}

    {A.metaPixel && (
      <>
        <!-- Meta (Facebook) Pixel -->
        <script is:inline define:vars={{ PIXEL_ID: A.metaPixel }}>
          !function(f,b,e,v,n,t,s)
          {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
          n.callMethod.apply(n,arguments):n.queue.push(arguments)};
          if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
          n.queue=[];t=b.createElement(e);t.async=!0;
          t.src=v;s=b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t,s)}(window, document,'script',
          'https://connect.facebook.net/en_US/fbevents.js');
          fbq('init', PIXEL_ID);
          fbq('track', 'PageView');
        </script>
      </>
    )}

    {A.hotjar && (
      <script is:inline define:vars={{ HJID: A.hotjar }}>
        (function(h,o,t,j,a,r){
          h.hj=h.hj||function(){(h.hj.q=h.hj.q||[]).push(arguments)};
          h._hjSettings={hjid:Number(HJID),hjsv:6};
          a=o.getElementsByTagName('head')[0];
          r=o.createElement('script');r.async=1;
          r.src=t+h._hjSettings.hjid+j+h._hjSettings.hjsv;
          a.appendChild(r);
        })(window,document,'https://static.hotjar.com/c/hotjar-','.js?sv=');
      </script>
    )}

    {A.linkedinPartnerId && (
      <script is:inline define:vars={{ LI_PID: A.linkedinPartnerId }}>
        window._linkedin_partner_id = LI_PID;
        window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
        window._linkedin_data_partner_ids.push(LI_PID);
        (function(l) {
          if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
          window.lintrk.q=[]}
          var s = document.getElementsByTagName("script")[0];
          var b = document.createElement("script");
          b.type = "text/javascript";b.async = true;
          b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
          s.parentNode.insertBefore(b, s);
        })(window.lintrk);
      </script>
    )}

    {A.mixpanelToken && (
      <script is:inline define:vars={{ MP_TOKEN: A.mixpanelToken, MP_PAGE: `Page View: ${siteConfig.siteName}` }}>
        (function(f,b){if(!b.__SV){var a,e,i,g;window.mixpanel=b;b._i=[];b.init=function(a,e,d){function f(b,h){var a=h.split(".");2==a.length&&(b=b[a[0]],h=a[1]);b[h]=function(){b.push([h].concat(Array.prototype.slice.call(arguments,0)))}}var c=b;"undefined"!==typeof d?c=b[d]=[]:d="mixpanel";c.people=c.people||[];c.toString=function(b){var a="mixpanel";"mixpanel"!==d&&(a+="."+d);b||(a+=" (stub)");return a};c.people.toString=function(){return c.toString(1)+".people (stub)"};i="disable time_event track track_pageview track_links track_forms register register_once alias unregister identify name_tag set_config reset people.set people.set_once people.unset people.increment people.append people.union people.track_charge people.clear_charges people.delete_user".split(" ");
        for(g=0;g<i.length;g++)f(c,i[g]);b._i.push([a,e,d])};b.__SV=1.2;a=f.createElement("script");a.type="text/javascript";a.async=!0;a.src="undefined"!==typeof MIXPANEL_CUSTOM_LIB_URL?MIXPANEL_CUSTOM_LIB_URL:"file:"===f.location.protocol&&"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js".match(/^\/\//)?"https://cdn.mxpnl.com/libs/mixpanel-2-latest.min.js":"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js";e=f.getElementsByTagName("script")[0];e.parentNode.insertBefore(a,e)}})(document,window.mixpanel||[]);
        mixpanel.init(MP_TOKEN, {batch_requests:true});
        mixpanel.track(MP_PAGE);
      </script>
    )}

    <!-- ══════════ EVENTO UNIFICADO DE CONVERSIÓN ══════════
         Cada vendor va en su propio try/catch: un fallo nunca rompe la cadena. -->
    <script is:inline define:vars={trackingVars}>
      window.trackConversionLead = function (actionName, payload) {
        payload = payload || {};
        var attribution = (window.getLeadAttribution && window.getLeadAttribution()) || {};
        var metadata = {
          site: SITE_ID,
          development: SITE_NAME,
          model: MODEL_NAME,
          action: actionName,
          page: location.pathname,
          timestamp: new Date().toISOString(),
          attribution: attribution,
        };
        for (var k in payload) metadata[k] = payload[k];

        // 1. Google Analytics 4 (+ Google Ads conversion si está configurado)
        if (typeof gtag === 'function') {
          try {
            gtag('event', 'generate_lead', {
              event_category: 'Engagement',
              event_label: actionName,
              value: LEAD_VALUE,
              currency: CURRENCY,
            });
            if (ADS_SEND_TO) {
              gtag('event', 'conversion', { send_to: ADS_SEND_TO, value: LEAD_VALUE, currency: CURRENCY });
            }
          } catch (e) {}
        }

        // 2. Meta Pixel Lead
        if (typeof fbq === 'function') {
          try {
            fbq('track', 'Lead', {
              content_name: SITE_NAME + ' - ' + MODEL_NAME,
              content_category: 'Property Lead',
              value: LEAD_VALUE,
              currency: CURRENCY,
              content_ids: [MODEL_ID],
              content_type: 'product',
            });
          } catch (e) {}
        }

        // 3. LinkedIn Insight
        if (LI_CONVERSION_ID && typeof lintrk === 'function') {
          try { lintrk('track', { conversion_id: Number(LI_CONVERSION_ID) }); } catch (e) {}
        }

        // 4. Mixpanel
        if (typeof mixpanel === 'object' && mixpanel.track) {
          try { mixpanel.track('Lead Conversion', metadata); } catch (e) {}
        }

        // 5. Webhook propio (pipeline de leads / OpenClaw) — sobrevive a la navegación con sendBeacon
        if (LEAD_WEBHOOK) {
          try {
            var body = JSON.stringify({ type: 'event', event: actionName, data: metadata });
            if (navigator.sendBeacon) {
              navigator.sendBeacon(LEAD_WEBHOOK, new Blob([body], { type: 'application/json' }));
            } else {
              fetch(LEAD_WEBHOOK, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: body, keepalive: true });
            }
          } catch (e) {}
        }
      };

      // Atribución → WhatsApp: al hacer clic en cualquier enlace wa.me se añade una línea
      // "Ref: sitio|fuente|campaña" al mensaje prellenado, para que el asesor (o la IA)
      // sepa de qué campaña llegó el lead sin necesidad de backend.
      document.addEventListener('click', function (ev) {
        var a = ev.target && ev.target.closest ? ev.target.closest('a[href^="https://wa.me/"]') : null;
        if (!a) return;
        try {
          var attr = (window.getLeadAttribution && window.getLeadAttribution()) || {};
          var last = attr.last || {};
          var source = last.utm_source || attr.utm_source || (attr.referrer ? 'referral' : 'directo');
          var campaign = last.utm_campaign || attr.utm_campaign || '';
          var url = new URL(a.href);
          var text = url.searchParams.get('text') || '';
          if (text.indexOf('Ref: ') === -1) {
            url.searchParams.set('text', text + '\n\nRef: ' + SITE_ID + '|' + source + (campaign ? '|' + campaign : ''));
            a.href = url.toString();
          }
        } catch (e) {}
      }, true);
    </script>
  </head>
  <body class="bg-black text-slate-200 font-sans antialiased">
    <!-- Subtle, Apple-like Top Bar -->
    <header class="absolute top-0 left-0 w-full z-50 pointer-events-none">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-center">
        <div class="flex items-center gap-2.5 pointer-events-auto mx-auto">
          <img
            src="/synexia-logo-transparent.png"
            alt="Synexia Bienes Raíces"
            width="171"
            height="120"
            decoding="async"
            class="h-5 w-auto object-contain opacity-80 hover:opacity-100 transition-opacity duration-300"
          />
          <span class="text-xs font-light tracking-widest text-neutral-300 uppercase opacity-75 hover:opacity-100 transition-opacity duration-300 select-none">
            Synexia Bienes Raíces
          </span>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
