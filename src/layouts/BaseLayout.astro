---
// BaseLayout.astro
// Global <head> tags, Open Graph meta, and JSON-LD Schema for GEO
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Lyrata Edén Urbano', description = '' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- JSON-LD / GEO Schema placeholder -->
    <script type="application/ld+json">
      {}
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
